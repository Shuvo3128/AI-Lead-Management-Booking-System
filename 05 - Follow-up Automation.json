    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "gpt-4",
          "mode": "list",
          "cachedResultName": "GPT-4"
        },
        "responses": {
          "values": [
            {
              "content": "=You are an AI sales follow-up assistant.\n\nWrite a short, polite, professional follow-up email for this lead.\n\nRules:\n- Keep it concise\n- Sound natural and human\n- Mention the lead's interest\n- Ask if they are still interested\n- Include a simple call to action\n- Return ONLY valid JSON\n- Do not include bullet points\n- Do not include labels like Name, Interest, Subject, or Explanation\n- Do not include markdown\n\nReturn JSON in this exact format:\n{\n  \"follow_up_message\": \"\"\n}\n\nLead Data:\n{{$json.followup_input}}"
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 2.1,
      "position": [
        256,
        -208
      ],
      "id": "8a87646b-573d-4fcc-a625-33aecba253e0",
      "name": "Generate Follow-up Email",
      "credentials": {
        "openAiApi": {
          "id": "fi3wwr185fV8OP8H",
          "name": "OpenAi account 2"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const raw = $json.output[0].content[0].text;\n\nlet parsed;\nlet cleaned = raw.trim();\n\ntry {\n  parsed = JSON.parse(cleaned);\n} catch (error) {\n  const match = cleaned.match(/\\{[\\s\\S]*\\}/);\n  if (!match) {\n    throw new Error(\"AI follow-up output is not valid JSON: \" + raw);\n  }\n  parsed = JSON.parse(match[0]);\n}\n\nreturn [\n  {\n    json: {\n      lead_id: $('Get Leads For Follow-up').first().json.id,\n      email: $('Get Leads For Follow-up').first().json.email,\n      full_name: $('Get Leads For Follow-up').first().json.full_name,\n      follow_up_count: $('Get Leads For Follow-up').first().json.follow_up_count,\n      follow_up_message: parsed.follow_up_message\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
