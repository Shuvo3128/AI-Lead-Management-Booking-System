    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT *\nFROM leads\nWHERE response_status = 'sent'\n  AND lead_reply_received = FALSE\n  AND (last_contacted_at IS NULL OR last_contacted_at < NOW() - INTERVAL '1 day')\n  AND follow_up_count < 3\nORDER BY id ASC\nLIMIT 1;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
