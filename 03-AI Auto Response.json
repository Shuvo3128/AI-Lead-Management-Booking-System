          "id": "FPi2oSiI2H03GMyI",
          "name": "OpenAi account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const raw = $json.output[0].content[0].text;\n\nlet parsed;\n\ntry {\n  parsed = JSON.parse(raw);\n} catch (error) {\n  throw new Error(\"AI response draft is not valid JSON: \" + raw);\n}\n\nreturn [\n  {\n    json: {\n      lead_id: $('Get Qualified Lead').first().json.id,\n      response_message: parsed.response_message\n    }\n  }\n];"
      },
