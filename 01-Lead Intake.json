      "name": "If"
    },
    {
      "parameters": {
        "jsCode": "let source = ($json.source || 'unknown').toLowerCase().trim();\n\nif (source.includes('facebook')) {\n  source = 'facebook_ads';\n} \nelse if (source.includes('google')) {\n  source = 'google_ads';\n}\nelse if (source.includes('website') || source.includes('web')) {\n  source = 'website_form';\n}\nelse if (source.includes('landing')) {\n  source = 'landing_page';\n}\nelse if (source.includes('manual')) {\n  source = 'manual_entry';\n}\nelse if (source.includes('crm')) {\n  source = 'crm';\n}\nelse if (source.includes('email')) {\n  source = 'email_inquiry';\n}\nelse {\n  source = 'unknown';\n}\n\nreturn [\n  {\n    json: {\n      ...$json,\n      source\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        336,
        -144
      ],
      "id": "f58e46b3-2f71-4bfc-8068-b081f4e5b94c",
      "name": "Normalize Source"
    },
    {
      "parameters": {
        "jsCode": "const text = ($json.message || '').toLowerCase();\n\nlet business_type = 'unknown';\n\nconst realEstateKeywords = [\n  'buy house',\n  'buy home',\n  'sell house',\n  'real estate',\n  'property',\n  'mortgage',\n  'realtor',\n  'house',\n  'home'\n];\n\nconst financeKeywords = [\n  'insurance',\n  'life insurance',\n  'financial planning',\n  'retirement',\n  'investment',\n  'annuity',\n  'wealth',\n  'policy',\n  'coverage'\n];\n\nif (realEstateKeywords.some(keyword => text.includes(keyword))) {\n  business_type = 'real_estate';\n}\nelse if (financeKeywords.some(keyword => text.includes(keyword))) {\n  business_type = 'financial_planning_insurance';\n}\n\nreturn [\n  {\n    json: {\n      ...$json,\n      business_type\n    }\n  }\n];"
      },
