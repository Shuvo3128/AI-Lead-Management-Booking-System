    },
    {
      "parameters": {
        "jsCode": "const full_name = $json.full_name || '';\nconst email = $json.email || '';\nconst phone = $json.phone || '';\n\nconst isValid = full_name.trim() !== '' && (email.trim() !== '' || phone.trim() !== '');\n\nreturn [\n  {\n    json: {\n      ...$json,\n      is_valid: isValid,\n      validation_reason: isValid ? \"valid lead\" : \"Missing name or both email and phone\"\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
