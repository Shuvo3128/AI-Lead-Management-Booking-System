      "name": "const full_name = $json.full_name || ''; const email = $json.email || ''; const phone = $json.phone || '';  const isValid = full_name.trim() !== '' && (email.trim() !== '' || phone.trim() !== '');  return [   {     json: {       ...$json,       is_valid: isValid,       validation_reason: isValid ? \"valid lead\" : \"Missing name or both email and phone\"     }   } ];"
    },
